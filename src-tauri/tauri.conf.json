{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "note_mark",
  "version": "0.1.0",
  "identifier": "com.notemark.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "note_mark",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.config/notemark/uploads/**",
          "$APPDATA/notemark/uploads/**",
          "$HOME/Library/Application Support/notemark/uploads/**"
        ]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
