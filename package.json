{
  "name": "note_mark",
  "private": true,
  "version": "1.0.1",
  "description": "A modern, cute Markdown editor with live preview and custom styling",
  "author": {
    "name": "CangLi",
    "email": "gl0wniapar@gmail.com"
  },
  "type": "module",
  "main": "dist-electron/index.cjs",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "node index.ts",
    "dev:tauri": "cd src-tauri && cargo tauri dev",
    "build": "vite build",
    "build:electron": "cross-env ELECTRON=true vite build && go build -C server -o cmd/server/server ./cmd/server/ && esbuild index.ts --bundle --platform=node --target=node18 --external:electron --format=cjs --define:import.meta.url=__importMetaUrl --banner:js=\"const __importMetaUrl = require('url').pathToFileURL(__filename).href;\" --outfile=dist-electron/index.cjs",
    "build:tauri": "cd src-tauri && APPIMAGE_EXTRACT_AND_RUN=1 cargo tauri build",
    "build:tauri:linux": "cd src-tauri && APPIMAGE_EXTRACT_AND_RUN=1 NO_STRIP=true cargo tauri build --bundles deb,appimage",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron release",
    "lint": "tsc --noEmit",
    "dist": "pnpm run build:electron && electron-builder",
    "dist:win": "cross-env ELECTRON=true vite build && cross-env GOOS=windows GOARCH=amd64 go build -C server -o cmd/server/server.exe ./cmd/server/ && esbuild index.ts --bundle --platform=node --target=node18 --external:electron --format=cjs --define:import.meta.url=__importMetaUrl --banner:js=\"const __importMetaUrl = require('url').pathToFileURL(__filename).href;\" --outfile=dist-electron/index.cjs && electron-builder --win",
    "dist:mac": "pnpm run build:electron && electron-builder --mac",
    "dist:linux": "pnpm run build:electron && electron-builder --linux"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@diplodoc/transform": "^4.73.0",
    "@fontsource/material-symbols-outlined": "^5.2.38",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/quicksand": "^5.2.10",
    "@google/genai": "^1.29.0",
    "@gravity-ui/components": "^4.18.0",
    "@gravity-ui/markdown-editor": "^15.37.0",
    "@gravity-ui/uikit": "^7.36.0",
    "@material/material-color-utilities": "^0.4.0",
    "@milkdown/crepe": "^7.20.0",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/plugin-highlight": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "@milkdown/utils": "^7.20.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.10.1",
    "@uiw/codemirror-theme-dracula": "^4.25.8",
    "@uiw/codemirror-theme-github": "^4.25.8",
    "@uiw/codemirror-theme-nord": "^4.25.8",
    "@uiw/codemirror-theme-sublime": "^4.25.8",
    "@uiw/codemirror-theme-vscode": "^4.25.8",
    "@uiw/react-codemirror": "^4.25.8",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^25.10.5",
    "lucide-react": "^0.546.0",
    "marked": "^17.0.5",
    "marked-gfm-heading-id": "^4.1.3",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "prosemirror-highlight": "^0.15.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.6.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "showdown": "^2.1.0",
    "sugar-high": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/showdown": "^2.0.6",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.notemark.app",
    "productName": "NoteMark",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!images/**/*",
      "!server/cmd/server/data/**/*",
      "!dist/uploads/**/*"
    ],
    "extraResources": [
      {
        "from": "server/cmd/server",
        "to": "server",
        "filter": [
          "**/*",
          "!data/**/*",
          "!public/uploads/**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.svg"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.svg"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "icon": "build/icon.svg",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
