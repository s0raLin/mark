{
  "name": "studiomark",
  "private": true,
  "version": "1.0.0",
  "description": "A modern, cute Markdown editor with live preview and custom styling",
  "author": "StudioMark Team",
  "type": "module",
  "main": "dist-electron/index.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "node index.ts",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "dist": "ELECTRON=true npm run build && npm run build:electron && electron-builder",
    "dist:win": "ELECTRON=true npm run build && npm run build:electron && electron-builder --win",
    "dist:mac": "ELECTRON=true npm run build && npm run build:electron && electron-builder --mac",
    "dist:linux": "ELECTRON=true npm run build && npm run build:electron && electron-builder --linux"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@uiw/codemirror-theme-dracula": "^4.25.8",
    "@uiw/codemirror-theme-github": "^4.25.8",
    "@uiw/codemirror-theme-nord": "^4.25.8",
    "@uiw/codemirror-theme-sublime": "^4.25.8",
    "@uiw/codemirror-theme-vscode": "^4.25.8",
    "@uiw/react-codemirror": "^4.25.8",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "showdown": "^2.1.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/showdown": "^2.0.6",
    "autoprefixer": "^10.4.21",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "build": {
    "appId": "com.studiomark.app",
    "productName": "StudioMark",
    "electronDist": "node_modules/electron/dist",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/**/*.md",
      "!node_modules/**/*.ts",
      "!node_modules/**/test/**/*",
      "!node_modules/**/tests/**/*",
      "!node_modules/**/__tests__/**/*"
    ],
    "extraResources": [
      {
        "from": "server/cmd/server",
        "to": "server",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/favicon.svg"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "public/favicon.svg"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "public/favicon.svg",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
